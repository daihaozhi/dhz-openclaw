# OpenClaw -> SGLang(OpenAI-compatible) configuration example
# Copy to .env (or your runtime environment file) on the machine where OpenClaw runs.

# SGLang endpoint from your remote Ubuntu host
OPENAI_BASE_URL=http://<REMOTE_UBUNTU_IP>:30000/v1
OPENAI_API_BASE=http://<REMOTE_UBUNTU_IP>:30000/v1
OPENAI_API_KEY=EMPTY

# Model served by SGLang
OPENAI_MODEL=Qwen/Qwen3-4B
MODEL_NAME=Qwen/Qwen3-4B

# Optional generation defaults
TEMPERATURE=0.2
MAX_TOKENS=2048
